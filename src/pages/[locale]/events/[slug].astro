---
import { render } from 'astro:content';

import SiteLayout from '../../../layouts/SiteLayout.astro';
import { type Locale } from '../../../i18n/config';
import { getLocalizedEntries } from '../../../lib/content';
import { withBasePath } from '../../../lib/url';

export async function getStaticPaths() {
  const paths: Array<{ params: { locale: Locale; slug: string } }> = [];

  for (const locale of ['zh', 'en'] as const) {
    const entries = await getLocalizedEntries('events', locale);
    for (const entry of entries) {
      paths.push({ params: { locale, slug: entry.slug } });
    }
  }

  return paths;
}

const locale = Astro.params.locale as Locale;
const slug = Astro.params.slug as string;

const entry = (await getLocalizedEntries('events', locale)).find((item) => item.slug === slug);
if (!entry) {
  return Astro.redirect(withBasePath(`${locale}/events`));
}

const { Content } = await render(entry);
---

<SiteLayout locale={locale} title={entry.data.title}>
  <article class="card">
    <h1>{entry.data.title}</h1>
    <p class="meta">{entry.data.dateLabel}</p>
    <Content />
  </article>
</SiteLayout>
