---
import SiteLayout from '../../layouts/SiteLayout.astro';
import ViewModeToggle from '../../components/ViewModeToggle.astro';
import { t, type Locale } from '../../i18n/config';
import { getLocalePaths, getLocalizedEntries, localizedPath } from '../../lib/content';

export function getStaticPaths() {
  return getLocalePaths();
}

const locale = Astro.params.locale as Locale;
const view = Astro.url.searchParams.get('view') === 'list' ? 'list' : 'interactive';
const organizations = await getLocalizedEntries('organizations', locale);

const relationTypes = [
  'friend',
  'ally',
  'colleague',
  'enemy',
  'leader',
  'teammate',
  'acquaintance',
] as const;

type RelationType = (typeof relationTypes)[number];

type RelationEdge = {
  source: (typeof organizations)[number];
  target: (typeof organizations)[number];
  type: RelationType;
  direction: 'undirected' | 'directed';
  note?: string;
};

const relationTypeSet = new Set<RelationType>(relationTypes);

const relationEdges: RelationEdge[] = organizations.flatMap((organization) => {
  const typedLinks = organization.data.related.organizationLinks
    .map((link) => {
      if (!relationTypeSet.has(link.type)) {
        return null;
      }

      const target = organizations.find((entry) => entry.data.entityId === link.targetId);
      if (!target) {
        return null;
      }

      return {
        source: organization,
        target,
        type: link.type,
        direction: link.direction,
        note: link.note,
      } satisfies RelationEdge;
    })
    .filter((entry): entry is RelationEdge => Boolean(entry));

  if (typedLinks.length > 0) {
    return typedLinks;
  }

  return organization.data.related.organizations
    .map((entityId) => {
      const target = organizations.find((entry) => entry.data.entityId === entityId);
      if (!target) {
        return null;
      }

      return {
        source: organization,
        target,
        type: 'acquaintance' as const,
        direction: 'undirected' as const,
      };
    })
    .filter((entry): entry is RelationEdge => Boolean(entry));
});

const relationRows = organizations
  .map((organization) => {
    const linked = relationEdges.filter(
      (edge) => edge.source.data.entityId === organization.data.entityId
    );

    return {
      organization,
      linked,
    };
  })
  .filter((row) => row.linked.length > 0);

const graphNodes = organizations.map((organization) => ({
  data: {
    id: organization.data.entityId,
    label: organization.data.name,
    href: localizedPath(locale, `organizations/${organization.slug}`),
  },
}));

const edgeMap = new Map<
  string,
  {
    data: {
      id: string;
      source: string;
      target: string;
      type: RelationType;
      direction: 'undirected' | 'directed';
      label: string;
    };
  }
>();

relationEdges.forEach((edge) => {
  const sourceId = edge.source.data.entityId;
  const targetId = edge.target.data.entityId;

  const id =
    edge.direction === 'undirected'
      ? `${[sourceId, targetId].sort().join('__')}__${edge.type}__undirected`
      : `${sourceId}__${targetId}__${edge.type}__directed`;

  if (!edgeMap.has(id)) {
    edgeMap.set(id, {
      data: {
        id,
        source: sourceId,
        target: targetId,
        type: edge.type,
        direction: edge.direction,
        label: t(locale, `labels.relationTypes.${edge.type}`),
      },
    });
  }
});

const graphData = {
  nodes: graphNodes,
  edges: Array.from(edgeMap.values()),
};
---

<SiteLayout locale={locale} title={t(locale, 'nav.organizationRelationship')}>
  <h1>{t(locale, 'nav.organizationRelationship')}</h1>
  <ViewModeToggle
    locale={locale}
    route="organization-relationship"
    activeView={view}
    interactiveValue="interactive"
    listValue="list"
  />
  <p class="meta">
    {locale === 'zh'
      ? '交互模式支持拖拽、缩放和点击组织节点跳转。'
      : 'Interactive mode supports pan, zoom, and click-to-open organization pages.'}
  </p>

  {
    relationRows.length === 0 ? (
      <article class="card">
        <p>
          {locale === 'zh'
            ? '暂时没有组织关系数据。请在组织条目的 related.organizationLinks 中填入关系。'
            : 'No organization relationship data yet. Add relations to related.organizationLinks in organization entries.'}
        </p>
      </article>
    ) : view === 'interactive' ? (
      <section class="card relationship-graph-wrap">
        <h2 class="relationship-legend-title">{t(locale, 'labels.relationLegend')}</h2>
        <ul class="relationship-legend">
          {relationTypes.map((type) => (
            <li>
              <span class={`legend-dot legend-${type}`} />
              {t(locale, `labels.relationTypes.${type}`)}
            </li>
          ))}
        </ul>
        <div id="organization-relationship-graph" class="relationship-graph"></div>
        <p class="meta relationship-tip">
          {locale === 'zh'
            ? '提示：滚轮缩放，拖动画布移动，点击节点进入组织页面。'
            : 'Tip: Use mouse wheel to zoom, drag the canvas to pan, and click a node to open an organization page.'}
        </p>
      </section>
    ) : (
      <section class="grid">
        {relationRows.map(({ organization, linked }) => (
          <article class="card">
            <h2>
              <a href={localizedPath(locale, `organizations/${organization.slug}`)}>
                {organization.data.name}
              </a>
            </h2>
            <ul>
              {linked.map((edge) => (
                <li>
                  <a href={localizedPath(locale, `organizations/${edge.target.slug}`)}>
                    {edge.target.data.name}
                  </a>
                  {' · '}
                  <span class="meta">{t(locale, `labels.relationTypes.${edge.type}`)}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </section>
    )
  }

  <script type="module" define:vars={{ graphData, locale }}>
    import cytoscape from 'cytoscape';

    const container = document.getElementById('organization-relationship-graph');
    if (!container || graphData.nodes.length === 0) {
      if (container) {
        container.textContent =
          locale === 'zh'
            ? '暂无可视化组织关系数据。'
            : 'No organization relationship data available for graph view.';
      }
    } else {
      const cy = cytoscape({
        container,
        elements: [...graphData.nodes, ...graphData.edges],
        style: [
          {
            selector: 'node',
            style: {
              'background-color': '#004f4a',
              label: 'data(label)',
              color: '#ffffff',
              'font-size': 11,
              'text-wrap': 'wrap',
              'text-max-width': 88,
              'text-valign': 'center',
              'text-halign': 'center',
              'text-outline-width': 0,
              width: 56,
              height: 56,
            },
          },
          {
            selector: 'edge',
            style: {
              width: 2,
              'line-color': '#8db8b2',
              'curve-style': 'bezier',
              opacity: 0.9,
              'target-arrow-shape': 'none',
            },
          },
          {
            selector: 'edge[direction = "directed"]',
            style: {
              'target-arrow-shape': 'triangle',
            },
          },
          { selector: 'edge[type = "friend"]', style: { 'line-color': '#2a9d8f' } },
          { selector: 'edge[type = "ally"]', style: { 'line-color': '#4f86c6' } },
          { selector: 'edge[type = "colleague"]', style: { 'line-color': '#8a7ca8' } },
          { selector: 'edge[type = "enemy"]', style: { 'line-color': '#d64545' } },
          { selector: 'edge[type = "leader"]', style: { 'line-color': '#22333b' } },
          { selector: 'edge[type = "teammate"]', style: { 'line-color': '#6c9a3b' } },
          { selector: 'edge[type = "acquaintance"]', style: { 'line-color': '#9a8f7a' } },
          {
            selector: ':selected',
            style: {
              'background-color': '#c26b3d',
              'line-color': '#c26b3d',
              'target-arrow-color': '#c26b3d',
              'source-arrow-color': '#c26b3d',
            },
          },
        ],
        layout: {
          name: 'cose',
          animate: true,
          animationDuration: 400,
          idealEdgeLength: 130,
          nodeRepulsion: 7800,
        },
      });

      cy.on('tap', 'node', (event) => {
        const href = event.target.data('href');
        if (href) {
          window.location.href = href;
        }
      });
    }
  </script>
</SiteLayout>
