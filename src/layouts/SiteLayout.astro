---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { t, type Locale } from '../i18n/config';
import { localizedPath } from '../lib/content';
import '../styles/site.css';

type Props = {
  locale: Locale;
  title: string;
};

const { locale, title } = Astro.props;

const navItems = [
  { label: t(locale, 'nav.worldview'), href: localizedPath(locale, 'worldview') },
  { label: t(locale, 'nav.relationship'), href: localizedPath(locale, 'relationship') },
  { label: t(locale, 'nav.timeline'), href: localizedPath(locale, 'timeline') },
  { label: t(locale, 'nav.map'), href: localizedPath(locale, 'map') },
];
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="top-nav">
      <nav>
        <ul>
          {
            navItems.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>
      <LanguageSwitcher locale={locale} pathname={Astro.url.pathname} />
    </header>
    <main class="page-wrap">
      <slot />
    </main>
  </body>
</html>
